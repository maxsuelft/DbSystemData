# Uso: cp docker-compose.yml.example docker-compose.yml
# Defina no .env o seu usuário do GitHub: GITHUB_USER=seu_usuario
# A imagem usada será: ghcr.io/SEU_USUARIO/dbsystemdata:latest
# (gerada pelo workflow .github/workflows/docker-build-push.yml)
#
# Para desenvolvimento local com build na máquina, use build: em vez de image: e
# comente a linha image: abaixo.

version: "3"

services:
  dbsystemdata:
    image: ghcr.io/${GITHUB_USER:-seu_usuario}/dbsystemdata:latest
    # build local (desenvolvimento): descomente as linhas abaixo e comente a linha image: acima
    # build:
    #   context: .
    #   dockerfile: Dockerfile
    ports:
      - "4005:4005"
    volumes:
      - ./dbsystemdata-data:/dbsystemdata-data
    container_name: dbsystemdata
    restart: unless-stopped